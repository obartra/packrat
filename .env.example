# Firebase Web SDK config — copy to .env.local and fill in values.
# All VITE_ prefixed vars are exposed to the client bundle.
# Get these from Firebase Console → Project Settings → Your apps → SDK setup and configuration.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — for authenticated Cypress E2E tests.
# Tests auto-skip when these are missing.
CYPRESS_TEST_EMAIL=
CYPRESS_TEST_PASSWORD=
