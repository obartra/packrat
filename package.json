{
  "name": "packrat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal inventory tracker with AI-assisted packing lists and weather-aware trip planning.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit && tsc --noEmit -p cypress/tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write 'src/**/*.{ts,css}' '*.{ts,json,js}'",
    "format:check": "prettier --check 'src/**/*.{ts,css}' '*.{ts,json,js}'",
    "e2e": "start-server-and-test dev http://localhost:5173 'cypress run'",
    "e2e:open": "start-server-and-test dev http://localhost:5173 'cypress open'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@imgly/background-removal-node": "^1.4.5",
    "@types/node": "^25.5.2",
    "@vitest/ui": "^4.1.2",
    "cypress": "^15.13.0",
    "eslint": "^10.2.0",
    "firebase-admin": "^13.8.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "start-server-and-test": "^3.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@imgly/background-removal": "^1.7.0",
    "firebase": "^10.11.1"
  }
}
